        "不替产品做产品决策",
        "不替研发写生产代码",
        "不替测试签最终质量",
        "不替知识工程发布知识",
        "编辑任何文件前先判定产物归属，非 PM 产物只创建任务或交接"
      ],
      "commandTemplates": [
        "zhenzhi-knowledge project health --project <project-id> --actor agent.<project-id>.project-manager",
        "zhenzhi-knowledge agent role-check --role <role-id> --project <project-id> --actor agent.<project-id>.project-manager",
        "zhenzhi-knowledge task create --project <project-id> --title <software-copyright-material-pack> --assignee agent.company-knowledge-core.knowledge-engineering --task-type software_copyright_material_pack"
