{
  "version": "agent-role-operating-specs.v1",
  "guideRef": "docs/agent-team/company-agent-team-operating-guide.md",
  "commonRulesRef": "docs/agent-team/common-agent-operating-rules.md",
  "thinkingFrameworkRef": "docs/agent-team/agent-delivery-thinking-framework.md",
  "receiverReviewPolicy": {
    "objectType": "ReceiverReview",
    "requiredBeforeDownstreamWork": [
      "design",
      "architecture",
      "development",
      "test",
      "operations",
      "knowledge-engineering"
    ],
    "continueDecisions": [
      "accepted_for_work",
      "accepted_with_assumptions"
    ],
    "stopDecisions": [
      "needs_rework",
      "human_decision_required"
    ],
    "rules": [
      "下游 Agent 接收上游交付物前必须创建 ReceiverReview。",
      "ReceiverReview 必须检查上游交付是否说清目标、对象、状态、路径、异常、依赖、证据、门禁和下一步；不要求上游填写固定模板。",
      "accepted_with_assumptions 必须写 assumptions 并在 TaskResult 中保留影响。",
      "needs_rework 必须回派上游 owner 返工。",
      "human_decision_required 必须交项目经理 Agent 路由人类决策。",
      "Feature 任务必须追溯 requirementRefs；Bugfix 任务必须追溯 defectRefs。"
    ]
  },
  "taskSourcePolicy": {
    "requiredTaskFields": [
      "workSourceType",
      "requirementRefs",
      "defectRefs",
      "receiverReviewRefs"
    ],
    "featureTaskRules": [
      "workSourceType 必须为 feature。",
      "requirementRefs 必须指向可追溯需求或验收标准。"
    ],
    "bugfixTaskRules": [
      "workSourceType 必须为 bugfix。",
      "defectRefs 必须指向 Defect；无需强制绑定 product requirement。"
    ],
    "receiverReviewRules": [
      "ReceiverReview decision 为 accepted_for_work 或 accepted_with_assumptions 时才可继续。",
      "ReceiverReview decision 为 needs_rework 或 human_decision_required 时必须停止流转。"
    ]
  },
  "roles": [
    {
      "roleId": "project-manager",
      "name": "项目经理 Agent",
      "defaultAgentId": "agent.company.project-manager",
      "primaryOwner": "agent.company.project-manager",
      "guideRef": "docs/agent-team/company-agent-team-operating-guide.md",
      "commonRulesRef": "docs/agent-team/common-agent-operating-rules.md",
      "thinkingFrameworkRef": "docs/agent-team/agent-delivery-thinking-framework.md",
      "receiverReviewGate": {
        "requiredFields": [
          "workSourceType",
          "requirementRefs",
          "defectRefs",
          "ReceiverReview"
        ],
        "continueDecisions": [
          "accepted_for_work",
          "accepted_with_assumptions"
        ],
        "stopDecisions": [
          "needs_rework",
          "human_decision_required"
        ],
        "rules": [
          "Project Manager must create or route ProjectTask with workSourceType.",
          "Feature work must preserve requirementRefs; bugfix/rework must preserve defectRefs.",
          "Project routing must expose target, receiver, current state, dependencies, evidence readiness, gate requirements, and next action before downstream work starts.",
          "Downstream work must not start until the receiving Agent records ReceiverReview."
        ]
      },
      "responsibilities": [
        "项目启动",
        "任务拆解",
        "跨岗位协同",
        "风险和阻塞管理",
        "验收路由",
        "状态通知",
        "交付闭环",
        "上线软著材料任务触发和追踪"
      ],
      "inputContract": [
        "项目目标",
        "项目上下文",
        "任务队列",
        "TaskResult",
        "Runner 状态",
        "通知状态",
        "审批状态"
